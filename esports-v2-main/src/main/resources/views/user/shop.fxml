<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<BorderPane xmlns="http://javafx.com/javafx"
            xmlns:fx="http://javafx.com/fxml"
            fx:controller="com.esports.controllers.user.ShopController"
            prefWidth="1200" prefHeight="700"
            style="-fx-padding: 20;">

    <top>
        <HBox spacing="10" alignment="CENTER_LEFT" style="-fx-padding: 0 0 15 0;">
            <Label text="Shop" style="-fx-font-size: 24; -fx-font-weight: bold;"/>
            <Region HBox.hgrow="ALWAYS"/>
            <TextField fx:id="searchField" promptText="Search products..." prefWidth="250"/>
            <Button text="Search" onAction="#handleSearch"/>
            <Button text="Refresh" onAction="#handleRefresh"/>
        </HBox>
    </top>

    <center>
        <ScrollPane fitToWidth="true" style="-fx-background-color: transparent;">
            <content>
                <FlowPane fx:id="productsContainer"
                          hgap="15" vgap="15"
                          prefWrapLength="760"
                          style="-fx-padding: 5;"/>
            </content>
        </ScrollPane>
    </center>

    <right>
        <VBox spacing="12" prefWidth="380" style="-fx-padding: 0 0 0 20;">

            <Label text="My Cart" style="-fx-font-size: 20; -fx-font-weight: bold;"/>
            <ListView fx:id="cartListView" prefHeight="170"/>

            <HBox spacing="10">
                <Button text="Remove Selected" onAction="#handleRemoveSelected"
                        style="-fx-background-color: #e74c3c; -fx-text-fill: white;"/>
                <Button text="Clear Cart" onAction="#handleClearCart"/>
            </HBox>

            <Label fx:id="cartTotalLabel" text="Cart Total: 0.00 TND"
                   style="-fx-font-size: 16; -fx-font-weight: bold;"/>

            <Separator/>

            <Label text="Customer Information" style="-fx-font-size: 18; -fx-font-weight: bold;"/>

            <VBox spacing="3">
                <TextField fx:id="firstNameField" promptText="First name"/>
                <Label fx:id="firstNameError" style="-fx-text-fill: red; -fx-font-size: 11;"/>
            </VBox>

            <VBox spacing="3">
                <TextField fx:id="lastNameField" promptText="Last name"/>
                <Label fx:id="lastNameError" style="-fx-text-fill: red; -fx-font-size: 11;"/>
            </VBox>

            <VBox spacing="3">
                <TextField fx:id="emailField" promptText="Email"/>
                <Label fx:id="emailError" style="-fx-text-fill: red; -fx-font-size: 11;"/>
            </VBox>

            <VBox spacing="3">
                <TextField fx:id="phoneField" promptText="Phone"/>
                <Label fx:id="phoneError" style="-fx-text-fill: red; -fx-font-size: 11;"/>
            </VBox>

            <VBox spacing="3">
                <ComboBox fx:id="paymentMethodBox" promptText="Payment method" prefWidth="220"/>
                <Label fx:id="paymentError" style="-fx-text-fill: red; -fx-font-size: 11;"/>
            </VBox>

            <Label fx:id="orderMessageLabel" wrapText="true" style="-fx-font-size: 12;"/>

            <Button text="Place Order" onAction="#handlePlaceOrder"
                    style="-fx-background-color: #2ecc71; -fx-text-fill: white; -fx-font-size: 14;"/>

            <Separator/>

            <Label text="Online Payment" style="-fx-font-size: 16; -fx-font-weight: bold;"/>

            <Button fx:id="payOnlineButton"
                    text="Pay Online"
                    onAction="#handlePayOnline"
                    style="-fx-background-color: #635bff; -fx-text-fill: white; -fx-font-size: 14;"/>

            <Button fx:id="confirmOnlinePaymentButton"
                    text="Confirm Payment"
                    onAction="#handleConfirmOnlinePayment"
                    style="-fx-background-color: #111827; -fx-text-fill: white; -fx-font-size: 14;"/>

        </VBox>
    </right>

</BorderPane>