<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.Insets?>

<StackPane xmlns="http://javafx.com/javafx"
           xmlns:fx="http://javafx.com/fxml"
           fx:controller="com.esports.controllers.SignaturePasswordRecoveryController"
           style="-fx-background-color: linear-gradient(135deg, #667eea 0%, #764ba2 100%);">

    <ScrollPane fitToWidth="true" style="-fx-background: transparent; -fx-background-color: transparent;" vbarPolicy="AS_NEEDED" hbarPolicy="NEVER">
        <VBox alignment="CENTER" spacing="0" maxWidth="500" minHeight="700" style="-fx-padding: 40 0;">
        
            <!-- Recovery Card -->
            <VBox alignment="CENTER" spacing="25" 
                  style="-fx-background-color: white; -fx-background-radius: 20; -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.3), 30, 0, 0, 10); -fx-padding: 50 40 40 40;">
                
                <!-- Header -->
                <VBox alignment="CENTER" spacing="8">
                    <Label text="🔐" style="-fx-font-size: 48;"/>
                    <Label text="Password Recovery" style="-fx-font-size: 28; -fx-font-weight: bold; -fx-text-fill: #667eea;"/>
                    <Label text="Verify your signature to reset your password" 
                           style="-fx-font-size: 13; -fx-text-fill: #888; -fx-text-alignment: center;" wrapText="true"/>
                </VBox>

                <!-- Form Fields -->
                <VBox spacing="20" prefWidth="400">
                    
                    <!-- Email Field -->
                    <VBox spacing="8">
                        <Label text="Email Address *" style="-fx-font-size: 13; -fx-font-weight: bold; -fx-text-fill: #333;"/>
                        <TextField fx:id="emailField" promptText="Enter your email" 
                                   style="-fx-background-color: #f7f7f7; -fx-border-color: #e0e0e0; -fx-border-radius: 10; -fx-background-radius: 10; -fx-padding: 12 15; -fx-font-size: 14;"/>
                    </VBox>

                    <!-- Signature Canvas -->
                    <VBox spacing="8" alignment="CENTER">
                        <Label text="Draw Your Signature *" style="-fx-font-size: 13; -fx-font-weight: bold; -fx-text-fill: #333;"/>
                        <Label text="Draw the same signature you used during registration" 
                               style="-fx-font-size: 11; -fx-text-fill: #888; -fx-font-style: italic;" wrapText="true"/>
                        <HBox fx:id="signatureCanvasContainer" alignment="CENTER" 
                              style="-fx-border-color: #e0e0e0; -fx-border-width: 2; -fx-border-radius: 10; -fx-background-color: white; -fx-background-radius: 10;"/>
                        <Button fx:id="clearSignatureButton" text="Clear Signature" onAction="#handleClearSignature" 
                                style="-fx-background-color: #f0f0f0; -fx-text-fill: #333; -fx-font-size: 12; -fx-font-weight: bold; -fx-padding: 8 0; -fx-background-radius: 10; -fx-cursor: hand;"
                                prefWidth="200"/>
                    </VBox>

                    <!-- New Password Field -->
                    <VBox spacing="8">
                        <Label text="New Password *" style="-fx-font-size: 13; -fx-font-weight: bold; -fx-text-fill: #333;"/>
                        <PasswordField fx:id="newPasswordField" promptText="Enter new password (min 4 characters)" 
                                       style="-fx-background-color: #f7f7f7; -fx-border-color: #e0e0e0; -fx-border-radius: 10; -fx-background-radius: 10; -fx-padding: 12 15; -fx-font-size: 14;"/>
                    </VBox>

                    <!-- Confirm Password Field -->
                    <VBox spacing="8">
                        <Label text="Confirm Password *" style="-fx-font-size: 13; -fx-font-weight: bold; -fx-text-fill: #333;"/>
                        <PasswordField fx:id="confirmPasswordField" promptText="Confirm new password" 
                                       style="-fx-background-color: #f7f7f7; -fx-border-color: #e0e0e0; -fx-border-radius: 10; -fx-background-radius: 10; -fx-padding: 12 15; -fx-font-size: 14;"/>
                    </VBox>

                    <!-- CAPTCHA -->
                    <VBox spacing="8">
                        <HBox spacing="10" alignment="CENTER_LEFT">
                            <Label fx:id="captchaQuestionLabel" text="5 + 3 = ?" 
                                   style="-fx-font-size: 13; -fx-font-weight: bold; -fx-text-fill: #667eea; -fx-background-color: #f0f4ff; -fx-padding: 10 15; -fx-background-radius: 8;"/>
                            <Button fx:id="refreshCaptchaButton" text="🔄" onAction="#handleRefreshCaptcha"
                                    style="-fx-background-color: #f0f0f0; -fx-text-fill: #333; -fx-font-size: 13; -fx-cursor: hand; -fx-background-radius: 8; -fx-padding: 8 12;">
                                <tooltip>
                                    <Tooltip text="Refresh CAPTCHA"/>
                                </tooltip>
                            </Button>
                        </HBox>
                        <TextField fx:id="captchaAnswerField" promptText="Enter answer" 
                                   style="-fx-background-color: #f7f7f7; -fx-border-color: #e0e0e0; -fx-border-radius: 10; -fx-background-radius: 10; -fx-padding: 12 15; -fx-font-size: 14;"/>
                    </VBox>

                    <!-- Error Label -->
                    <Label fx:id="errorLabel" wrapText="true" visible="false" 
                           style="-fx-text-fill: #e74c3c; -fx-font-size: 13; -fx-padding: 10; -fx-background-color: #ffe6e6; -fx-background-radius: 8;"/>

                    <!-- Success Label -->
                    <Label fx:id="successLabel" wrapText="true" visible="false" 
                           style="-fx-text-fill: #27ae60; -fx-font-size: 13; -fx-padding: 10; -fx-background-color: #e6ffe6; -fx-background-radius: 8;"/>

                    <!-- Reset Password Button -->
                    <Button fx:id="resetPasswordButton" text="Reset Password" onAction="#handleResetPassword" 
                            style="-fx-background-color: linear-gradient(135deg, #667eea 0%, #764ba2 100%); -fx-text-fill: white; -fx-font-size: 15; -fx-font-weight: bold; -fx-padding: 14 0; -fx-background-radius: 10; -fx-cursor: hand;"
                            prefWidth="400">
                        <effect>
                            <javafx.scene.effect.DropShadow color="rgba(102, 126, 234, 0.4)" radius="10" offsetY="5"/>
                        </effect>
                    </Button>

                    <!-- Back to Login Button -->
                    <Button fx:id="backToLoginButton" text="← Back to Login" onAction="#handleBackToLogin" 
                            style="-fx-background-color: transparent; -fx-text-fill: #667eea; -fx-font-size: 13; -fx-cursor: hand; -fx-underline: false;"
                            prefWidth="400"/>

                </VBox>

                <!-- Info Box -->
                <VBox spacing="8" style="-fx-background-color: #f0f4ff; -fx-padding: 15; -fx-background-radius: 10;">
                    <Label text="ℹ️ How it works:" style="-fx-font-size: 12; -fx-font-weight: bold; -fx-text-fill: #667eea;"/>
                    <Label text="1. Enter your email address" style="-fx-font-size: 11; -fx-text-fill: #666;" wrapText="true"/>
                    <Label text="2. Draw your signature (same as registration)" style="-fx-font-size: 11; -fx-text-fill: #666;" wrapText="true"/>
                    <Label text="3. Enter your new password" style="-fx-font-size: 11; -fx-text-fill: #666;" wrapText="true"/>
                    <Label text="4. If signature matches, password will be reset" style="-fx-font-size: 11; -fx-text-fill: #666;" wrapText="true"/>
                </VBox>

            </VBox>
        </VBox>
    </ScrollPane>
</StackPane>
