<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.Insets?>

<VBox spacing="15" style="-fx-background-color: #1e1e2e; -fx-padding: 25;"
      xmlns="http://javafx.com/javafx"
      xmlns:fx="http://javafx.com/fxml"
      fx:controller="com.esports.controllers.admin.TeamFormController" prefWidth="450">

    <Label fx:id="formTitle" text="Add Team"
           style="-fx-text-fill: white; -fx-font-size: 22; -fx-font-weight: bold;"/>

    <ScrollPane fitToWidth="true" style="-fx-background: transparent; -fx-background-color: transparent; -fx-hbar-policy: never;">
        <GridPane hgap="15" vgap="10">
            <columnConstraints>
                <ColumnConstraints minWidth="100" prefWidth="100" />
                <ColumnConstraints hgrow="ALWAYS" />
            </columnConstraints>

            <Label text="Team Name:" style="-fx-text-fill: #a6adc8;" GridPane.rowIndex="0" GridPane.columnIndex="0"/>
            <VBox spacing="5" GridPane.rowIndex="0" GridPane.columnIndex="1">
                <TextField fx:id="nameField" promptText="Enter team name"/>
                <Label fx:id="nameError" text="Team name is required" style="-fx-text-fill: #f38ba8; -fx-font-size: 11;" visible="false" managed="false"/>
            </VBox>

            <Label text="Logo Path:" style="-fx-text-fill: #a6adc8;" GridPane.rowIndex="1" GridPane.columnIndex="0"/>
            <VBox spacing="5" GridPane.rowIndex="1" GridPane.columnIndex="1">
                <HBox spacing="8">
                    <TextField fx:id="logoField" promptText="logo-filename.png" HBox.hgrow="ALWAYS"/>
                    <Button text="Browse..." onAction="#handleBrowse" style="-fx-background-color: #313244; -fx-text-fill: white;"/>
                </HBox>
                <Label fx:id="logoError" text="Please provide a logo path" style="-fx-text-fill: #f38ba8; -fx-font-size: 11;" visible="false" managed="false"/>
            </VBox>

            <Label text="Description:" style="-fx-text-fill: #a6adc8;" GridPane.rowIndex="2" GridPane.columnIndex="0"/>
            <VBox spacing="5" GridPane.rowIndex="2" GridPane.columnIndex="1">
                <TextArea fx:id="descField" promptText="Describe the team..." prefHeight="80" wrapText="true"/>
                <Label fx:id="descError" text="Description is required" style="-fx-text-fill: #f38ba8; -fx-font-size: 11;" visible="false" managed="false"/>
            </VBox>

            <Label text="Captain ID:" style="-fx-text-fill: #a6adc8;" GridPane.rowIndex="3" GridPane.columnIndex="0"/>
            <VBox spacing="5" GridPane.rowIndex="3" GridPane.columnIndex="1">
                <TextField fx:id="captainField" promptText="e.g. 1"/>
                <Label fx:id="captainError" text="Must be a valid user ID" style="-fx-text-fill: #f38ba8; -fx-font-size: 11;" visible="false" managed="false"/>
            </VBox>
        </GridPane>
    </ScrollPane>

    <HBox spacing="10" alignment="CENTER_RIGHT" style="-fx-padding: 10 0 0 0;">
        <Button text="Cancel" onAction="#handleCancel" style="-fx-background-color: #313244; -fx-text-fill: white; -fx-cursor: hand;"/>
        <Button text="Delete" fx:id="deleteBtn" onAction="#handleDelete" style="-fx-background-color: #f38ba8; -fx-text-fill: white; -fx-cursor: hand;"/>
        <Button text="Save Team" onAction="#handleSave" style="-fx-background-color: #89b4fa; -fx-text-fill: white; -fx-font-weight: bold; -fx-cursor: hand;"/>
    </HBox>

</VBox>