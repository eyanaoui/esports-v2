<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.Insets?>

<VBox spacing="15" style="-fx-background-color: #1e1e2e; -fx-padding: 25;" xmlns:fx="http://javafx.com/fxml"
      fx:controller="com.esports.controllers.admin.TournamentFormController" prefWidth="580">

    <Label fx:id="formTitle" text="Add Tournament" style="-fx-text-fill: white; -fx-font-size: 24; -fx-font-weight: bold;"/>

    <ScrollPane fitToWidth="true" style="-fx-background: transparent; -fx-background-color: transparent; -fx-hbar-policy: never;">
        <GridPane hgap="20" vgap="10">
            <columnConstraints>
                <ColumnConstraints percentWidth="50"/>
                <ColumnConstraints percentWidth="50"/>
            </columnConstraints>

            <VBox GridPane.columnIndex="0" GridPane.rowIndex="0" spacing="5">
                <Label text="Tournament Name" style="-fx-text-fill: #a6adc8;"/>
                <TextField fx:id="nameField" promptText="e.g. Winter Clash"/>
                <Label fx:id="nameError" text="Name is required" style="-fx-text-fill: #f38ba8; -fx-font-size: 11;" visible="false" managed="false"/>
            </VBox>

            <VBox GridPane.columnIndex="1" GridPane.rowIndex="0" spacing="5">
                <Label text="Game" style="-fx-text-fill: #a6adc8;"/>
                <TextField fx:id="gameField" promptText="e.g. Valorant"/>
                <Label fx:id="gameError" text="Game is required" style="-fx-text-fill: #f38ba8; -fx-font-size: 11;" visible="false" managed="false"/>
            </VBox>

            <VBox GridPane.columnIndex="0" GridPane.rowIndex="1" spacing="5">
                <Label text="Format" style="-fx-text-fill: #a6adc8;"/>
                <ComboBox fx:id="formatCombo" promptText="Select Format" maxWidth="Infinity"/>
                <Label fx:id="formatError" text="Select a format" style="-fx-text-fill: #f38ba8; -fx-font-size: 11;" visible="false" managed="false"/>
            </VBox>

            <VBox GridPane.columnIndex="1" GridPane.rowIndex="1" spacing="5">
                <Label text="Max Teams" style="-fx-text-fill: #a6adc8;"/>
                <TextField fx:id="maxTeamsField" promptText="e.g. 16"/>
                <Label fx:id="maxTeamsError" text="Must be a positive number" style="-fx-text-fill: #f38ba8; -fx-font-size: 11;" visible="false" managed="false"/>
            </VBox>

            <VBox GridPane.columnIndex="0" GridPane.rowIndex="2" spacing="5">
                <Label text="Start Date" style="-fx-text-fill: #a6adc8;"/>
                <DatePicker fx:id="startDatePicker" maxWidth="Infinity"/>
                <Label fx:id="dateError" text="Start date is required" style="-fx-text-fill: #f38ba8; -fx-font-size: 11;" visible="false" managed="false"/>
            </VBox>

            <VBox GridPane.columnIndex="1" GridPane.rowIndex="2" spacing="5">
                <Label text="Reg. Deadline" style="-fx-text-fill: #a6adc8;"/>
                <DatePicker fx:id="deadlinePicker" maxWidth="Infinity"/>
                <Label fx:id="deadlineError" text="Deadline is required" style="-fx-text-fill: #f38ba8; -fx-font-size: 11;" visible="false" managed="false"/>
            </VBox>

            <VBox GridPane.columnIndex="0" GridPane.rowIndex="3" spacing="5">
                <Label text="Prize Pool" style="-fx-text-fill: #a6adc8;"/>
                <TextField fx:id="prizeField" promptText="e.g. 1000 TND"/>
                <Label fx:id="prizeError" text="Enter prize (or 'None')" style="-fx-text-fill: #f38ba8; -fx-font-size: 11;" visible="false" managed="false"/>
            </VBox>

            <VBox GridPane.columnIndex="1" GridPane.rowIndex="3" spacing="5">
                <Label text="Status" style="-fx-text-fill: #a6adc8;"/>
                <ComboBox fx:id="statusCombo" promptText="Status" maxWidth="Infinity"/>
                <Label fx:id="statusError" text="Select a status" style="-fx-text-fill: #f38ba8; -fx-font-size: 11;" visible="false" managed="false"/>
            </VBox>

            <VBox GridPane.columnSpan="2" GridPane.rowIndex="4" spacing="5">
                <Label text="Description" style="-fx-text-fill: #a6adc8;"/>
                <TextArea fx:id="descArea" prefHeight="80" wrapText="true" promptText="Tournament details and rules..."/>
                <Label fx:id="descError" text="Description is required" style="-fx-text-fill: #f38ba8; -fx-font-size: 11;" visible="false" managed="false"/>
            </VBox>
        </GridPane>
    </ScrollPane>

    <HBox spacing="10" alignment="CENTER_RIGHT" style="-fx-padding: 10 0 0 0;">
        <Button text="Cancel" onAction="#handleCancel" style="-fx-background-color: #313244; -fx-text-fill: white; -fx-cursor: hand;"/>
        <Button fx:id="deleteBtn" text="Delete" onAction="#handleDelete" style="-fx-background-color: #f38ba8; -fx-text-fill: white; -fx-cursor: hand;"/>
        <Button text="Save Tournament" onAction="#handleSave" style="-fx-background-color: #89b4fa; -fx-text-fill: white; -fx-font-weight: bold; -fx-cursor: hand;"/>
    </HBox>
</VBox>