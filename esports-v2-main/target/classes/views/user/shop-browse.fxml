<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<BorderPane xmlns="http://javafx.com/javafx"
            xmlns:fx="http://javafx.com/fxml"
            fx:controller="com.esports.controllers.user.ShopBrowseController"
            prefWidth="1250"
            prefHeight="760"
            style="-fx-background-color: linear-gradient(to bottom right, #070914, #101326, #171b34);">

    <top>
        <VBox spacing="18" style="-fx-padding: 26 30 18 30;">

            <!-- HERO SECTION -->
            <HBox spacing="18"
                  alignment="CENTER_LEFT"
                  style="-fx-background-color: linear-gradient(to right, #15172f, #25105c, #0f172a);
                         -fx-background-radius: 24;
                         -fx-padding: 24;
                         -fx-border-color: rgba(147, 51, 234, 0.55);
                         -fx-border-radius: 24;
                         -fx-effect: dropshadow(gaussian, rgba(99,91,255,0.35), 28, 0, 0, 8);">

                <VBox spacing="8">
                    <Label text="⚡ ESPORTS GEAR SHOP"
                           style="-fx-font-size: 34;
                                  -fx-font-weight: bold;
                                  -fx-text-fill: white;"/>

                    <Label text="Build your setup. Upgrade your game. Get smart recommendations while shopping."
                           style="-fx-text-fill: #c7d2fe;
                                  -fx-font-size: 14;"/>

                    <HBox spacing="10">
                        <Label text="Gaming Accessories"
                               style="-fx-background-color: rgba(99,102,241,0.25);
                                      -fx-text-fill: #c7d2fe;
                                      -fx-padding: 6 12;
                                      -fx-background-radius: 999;
                                      -fx-font-size: 12;"/>

                        <Label text="Smart Recommendations"
                               style="-fx-background-color: rgba(34,197,94,0.18);
                                      -fx-text-fill: #86efac;
                                      -fx-padding: 6 12;
                                      -fx-background-radius: 999;
                                      -fx-font-size: 12;"/>

                        <Label text="Secure Checkout"
                               style="-fx-background-color: rgba(236,72,153,0.18);
                                      -fx-text-fill: #f9a8d4;
                                      -fx-padding: 6 12;
                                      -fx-background-radius: 999;
                                      -fx-font-size: 12;"/>
                    </HBox>
                </VBox>

                <Region HBox.hgrow="ALWAYS"/>

                <VBox spacing="10" alignment="CENTER_RIGHT">
                    <Label fx:id="cartCountLabel"
                           text="Items: 0"
                           style="-fx-background-color: rgba(255,255,255,0.12);
                                  -fx-text-fill: white;
                                  -fx-background-radius: 999;
                                  -fx-padding: 9 18;
                                  -fx-font-weight: bold;"/>

                    <Button text="Proceed to Checkout →"
                            onAction="#handleGoToCheckout"
                            style="-fx-background-color: linear-gradient(to right, #22c55e, #16a34a);
                                   -fx-text-fill: white;
                                   -fx-font-weight: bold;
                                   -fx-background-radius: 14;
                                   -fx-padding: 13 22;
                                   -fx-font-size: 14;
                                   -fx-cursor: hand;"/>
                </VBox>
            </HBox>

            <!-- FILTER BAR -->
            <HBox spacing="12"
                  alignment="CENTER_LEFT"
                  style="-fx-background-color: rgba(255,255,255,0.06);
                         -fx-background-radius: 18;
                         -fx-padding: 14;
                         -fx-border-color: rgba(255,255,255,0.08);
                         -fx-border-radius: 18;">

                <TextField fx:id="searchField"
                           promptText="Search headset, controller, console..."
                           prefWidth="310"
                           style="-fx-background-color: #0f172a;
                                  -fx-text-fill: white;
                                  -fx-prompt-text-fill: #8b8fae;
                                  -fx-background-radius: 14;
                                  -fx-border-color: #2b315d;
                                  -fx-border-radius: 14;
                                  -fx-padding: 11;"/>

                <ComboBox fx:id="categoryFilterBox"
                          onAction="#handleCategoryFilter"
                          prefWidth="170"
                          style="-fx-background-color: #0f172a;
                                 -fx-background-radius: 14;
                                 -fx-border-color: #2b315d;
                                 -fx-border-radius: 14;"/>

                <ComboBox fx:id="sortBox"
                          onAction="#handleSort"
                          prefWidth="190"
                          style="-fx-background-color: #0f172a;
                                 -fx-background-radius: 14;
                                 -fx-border-color: #2b315d;
                                 -fx-border-radius: 14;"/>

                <Button text="Search"
                        onAction="#handleSearch"
                        style="-fx-background-color: linear-gradient(to right, #8b5cf6, #6366f1);
                               -fx-text-fill: white;
                               -fx-font-weight: bold;
                               -fx-background-radius: 14;
                               -fx-padding: 10 18;
                               -fx-cursor: hand;"/>

                <Button text="Refresh"
                        onAction="#handleRefresh"
                        style="-fx-background-color: transparent;
                               -fx-border-color: #475569;
                               -fx-text-fill: #e5e7eb;
                               -fx-background-radius: 14;
                               -fx-border-radius: 14;
                               -fx-padding: 10 18;
                               -fx-cursor: hand;"/>

                <Region HBox.hgrow="ALWAYS"/>

                <Label fx:id="messageLabel"
                       wrapText="true"
                       style="-fx-text-fill: #a7f3d0;
                              -fx-font-size: 12;
                              -fx-font-weight: bold;"/>
            </HBox>
        </VBox>
    </top>

    <center>
        <ScrollPane fitToWidth="true"
                    style="-fx-background: transparent;
                           -fx-background-color: transparent;
                           -fx-padding: 0;">
            <content>
                <VBox spacing="28" style="-fx-padding: 0 30 30 30;">

                    <!-- PRODUCTS SECTION -->
                    <VBox spacing="14"
                          style="-fx-background-color: rgba(255,255,255,0.04);
                                 -fx-background-radius: 22;
                                 -fx-padding: 20;
                                 -fx-border-color: rgba(255,255,255,0.07);
                                 -fx-border-radius: 22;">

                        <HBox alignment="CENTER_LEFT">
                            <VBox spacing="3">
                                <Label text="🔥 Featured Products"
                                       style="-fx-font-size: 24;
                                              -fx-font-weight: bold;
                                              -fx-text-fill: white;"/>

                                <Label text="Choose your gaming equipment and add it to your cart."
                                       style="-fx-text-fill: #94a3b8;
                                              -fx-font-size: 13;"/>
                            </VBox>

                            <Region HBox.hgrow="ALWAYS"/>

                            <Label text="LIVE STOCK"
                                   style="-fx-background-color: rgba(34,197,94,0.16);
                                          -fx-text-fill: #86efac;
                                          -fx-padding: 7 13;
                                          -fx-background-radius: 999;
                                          -fx-font-weight: bold;
                                          -fx-font-size: 11;"/>
                        </HBox>

                        <FlowPane fx:id="productsContainer"
                                  hgap="20"
                                  vgap="20"
                                  prefWrapLength="790"/>
                    </VBox>

                    <!-- RECOMMENDATIONS SECTION -->
                    <VBox spacing="14"
                          style="-fx-background-color: rgba(139,92,246,0.08);
                                 -fx-background-radius: 22;
                                 -fx-padding: 20;
                                 -fx-border-color: rgba(139,92,246,0.25);
                                 -fx-border-radius: 22;">

                        <HBox alignment="CENTER_LEFT">
                            <VBox spacing="3">
                                <Label text="🤖 Recommended For You"
                                       style="-fx-font-size: 24;
                                              -fx-font-weight: bold;
                                              -fx-text-fill: white;"/>

                                <Label text="Smart suggestions based on your cart and popular products."
                                       style="-fx-text-fill: #c4b5fd;
                                              -fx-font-size: 13;"/>
                            </VBox>

                            <Region HBox.hgrow="ALWAYS"/>

                            <Label text="AI READY"
                                   style="-fx-background-color: rgba(99,102,241,0.22);
                                          -fx-text-fill: #c7d2fe;
                                          -fx-padding: 7 13;
                                          -fx-background-radius: 999;
                                          -fx-font-weight: bold;
                                          -fx-font-size: 11;"/>
                        </HBox>

                        <FlowPane fx:id="recommendationsContainer"
                                  hgap="16"
                                  vgap="16"
                                  prefWrapLength="790"/>
                    </VBox>

                </VBox>
            </content>
        </ScrollPane>
    </center>

    <right>
        <VBox spacing="16"
              prefWidth="360"
              style="-fx-padding: 26 24 24 20;
                     -fx-background-color: linear-gradient(to bottom, #101326, #0b1020);
                     -fx-border-color: rgba(255,255,255,0.08);
                     -fx-border-width: 0 0 0 1;">

            <VBox spacing="4">
                <Label text="🛒 Battle Cart"
                       style="-fx-font-size: 25;
                              -fx-font-weight: bold;
                              -fx-text-fill: white;"/>

                <Label text="Your selected gaming gear"
                       style="-fx-text-fill: #94a3b8;
                              -fx-font-size: 12;"/>
            </VBox>

            <ListView fx:id="cartListView"
                      prefHeight="325"
                      style="-fx-background-color: #0f172a;
                             -fx-background-radius: 16;
                             -fx-border-color: #2b315d;
                             -fx-border-radius: 16;"/>

            <HBox spacing="10">
                <Button text="Remove"
                        onAction="#handleRemoveSelected"
                        HBox.hgrow="ALWAYS"
                        maxWidth="Infinity"
                        style="-fx-background-color: #dc2626;
                               -fx-text-fill: white;
                               -fx-font-weight: bold;
                               -fx-background-radius: 12;
                               -fx-padding: 10;
                               -fx-cursor: hand;"/>

                <Button text="Clear"
                        onAction="#handleClearCart"
                        HBox.hgrow="ALWAYS"
                        maxWidth="Infinity"
                        style="-fx-background-color: #1f2937;
                               -fx-text-fill: #e5e7eb;
                               -fx-font-weight: bold;
                               -fx-background-radius: 12;
                               -fx-padding: 10;
                               -fx-cursor: hand;"/>
            </HBox>

            <Separator style="-fx-background-color: #2b315d;"/>

            <VBox spacing="6"
                  style="-fx-background-color: rgba(34,197,94,0.10);
                         -fx-background-radius: 18;
                         -fx-padding: 16;
                         -fx-border-color: rgba(34,197,94,0.25);
                         -fx-border-radius: 18;">

                <Label text="Cart Total"
                       style="-fx-text-fill: #86efac;
                              -fx-font-size: 12;
                              -fx-font-weight: bold;"/>

                <Label fx:id="cartTotalLabel"
                       text="Total: 0.00 TND"
                       style="-fx-font-size: 24;
                              -fx-font-weight: bold;
                              -fx-text-fill: white;"/>
            </VBox>

            <Button text="Checkout Now"
                    onAction="#handleGoToCheckout"
                    maxWidth="Infinity"
                    style="-fx-background-color: linear-gradient(to right, #22c55e, #16a34a);
                           -fx-text-fill: white;
                           -fx-font-weight: bold;
                           -fx-font-size: 15;
                           -fx-background-radius: 16;
                           -fx-padding: 14;
                           -fx-cursor: hand;"/>

            <VBox spacing="8"
                  style="-fx-background-color: rgba(99,102,241,0.10);
                         -fx-background-radius: 16;
                         -fx-padding: 14;
                         -fx-border-color: rgba(99,102,241,0.20);
                         -fx-border-radius: 16;">

                <Label text="💡 Pro Tip"
                       style="-fx-text-fill: #c7d2fe;
                              -fx-font-weight: bold;"/>

                <Label text="Add products to your cart to unlock smarter recommendations."
                       wrapText="true"
                       style="-fx-text-fill: #94a3b8;
                              -fx-font-size: 12;"/>
            </VBox>

        </VBox>
    </right>

</BorderPane>