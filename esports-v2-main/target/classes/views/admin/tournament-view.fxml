<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<VBox spacing="20" style="-fx-background-color: #0f111a; -fx-padding: 30;"
      xmlns="http://javafx.com/javafx"
      xmlns:fx="http://javafx.com/fxml"
      fx:controller="com.esports.controllers.admin.TournamentController">

    <HBox alignment="CENTER_LEFT" spacing="20">
        <VBox>
            <Label text="TOURNAMENT OVERVIEW" style="-fx-font-size: 26; -fx-font-weight: bold; -fx-text-fill: white; -fx-letter-spacing: 1.5;"/>
            <Label text="Monitor competitions and AI insights" style="-fx-font-size: 13; -fx-text-fill: #6b7280;"/>
        </VBox>
        <Region HBox.hgrow="ALWAYS" />
        <Button text="📥 EXPORT" onAction="#handleExportReport"
                style="-fx-background-color: #4ade80; -fx-text-fill: white; -fx-font-weight: bold; -fx-padding: 10 20; -fx-background-radius: 8; -fx-cursor: hand;"/>

        <Button text="⚖ AI FAIR MATCHMAKING" onAction="#handleFairMatchmaking"
                style="-fx-background-color: #94e2d5; -fx-text-fill: white; -fx-font-weight: bold; -fx-padding: 10 20; -fx-background-radius: 8; -fx-cursor: hand;"/>

        <Button text="🤖 AI PREDICT" onAction="#handleAIPrediction"
                style="-fx-background-color: #8b5cf6; -fx-text-fill: white; -fx-font-weight: bold; -fx-padding: 10 20; -fx-background-radius: 8; -fx-cursor: hand;"/>

        <Button text="+ CREATE NEW" onAction="#handleAdd"
                style="-fx-background-color: #3b82f6; -fx-text-fill: white; -fx-font-weight: bold; -fx-padding: 10 20; -fx-background-radius: 8; -fx-cursor: hand;"/>
    </HBox>

    <StackPane style="-fx-background-color: #1a1d29; -fx-background-radius: 12; -fx-padding: 12; -fx-border-color: #2d3142; -fx-border-radius: 12;">
        <TextField fx:id="searchField" promptText="Filter by name, game, or status..."
                   style="-fx-background-color: #0f111a; -fx-text-fill: white; -fx-prompt-text-fill: #4b5563; -fx-background-radius: 8; -fx-padding: 10; -fx-border-color: transparent;"
                   onKeyReleased="#handleSearch"/>
    </StackPane>

    <TableView fx:id="tournamentTable" VBox.vgrow="ALWAYS"
               style="-fx-background-color: transparent; -fx-border-color: transparent; -fx-table-header-border-color: transparent;">
        <columns>
            <TableColumn fx:id="colName" text="TOURNAMENT NAME" prefWidth="200" style="-fx-font-weight: bold; -fx-text-fill: white;"/>
            <TableColumn fx:id="colGame" text="GAME" prefWidth="120" style="-fx-text-fill: #3b82f6;"/>
            <TableColumn fx:id="colStartDate" text="START DATE" prefWidth="150" style="-fx-text-fill: #9ca3af;"/>
            <TableColumn fx:id="colStatus" text="STATUS" prefWidth="120" style="-fx-alignment: CENTER;"/>
            <TableColumn fx:id="colActions" text="ACTIONS" prefWidth="140" style="-fx-alignment: CENTER;"/>
        </columns>
        <columnResizePolicy>
            <TableView fx:constant="CONSTRAINED_RESIZE_POLICY" />
        </columnResizePolicy>
    </TableView>

</VBox>