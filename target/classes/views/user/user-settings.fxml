<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.image.ImageView?>
<?import javafx.scene.image.Image?>
<?import javafx.geometry.Insets?>

<VBox spacing="20" style="-fx-padding: 30; -fx-background-color: #f5f5f5;"
      xmlns="http://javafx.com/javafx"
      xmlns:fx="http://javafx.com/fxml"
      fx:controller="com.esports.controllers.user.UserSettingsController">

    <!-- Header -->
    <HBox alignment="CENTER_LEFT" spacing="15">
        <Button text="← Back" onAction="#handleBack" styleClass="back-btn"/>
        <Region HBox.hgrow="ALWAYS"/>
        <Label text="Account Settings" style="-fx-font-size: 28; -fx-font-weight: bold; -fx-text-fill: #333;"/>
        <Region HBox.hgrow="ALWAYS"/>
        <Button text="🚪 Logout" onAction="#handleLogout" styleClass="logout-btn"/>
    </HBox>

    <Separator/>

    <!-- Settings Container -->
    <ScrollPane fitToWidth="true" prefHeight="600" style="-fx-background-color: transparent;">
        <VBox spacing="25" style="-fx-padding: 20;">
            
            <!-- Profile Section -->
            <VBox spacing="15" style="-fx-background-color: white; -fx-padding: 25; -fx-background-radius: 15; -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.1), 10, 0, 0, 2);">
                <Label text="Profile Information" style="-fx-font-size: 20; -fx-font-weight: bold; -fx-text-fill: #667eea;"/>
                
                <HBox spacing="20" alignment="CENTER_LEFT">
                    <!-- Profile Picture -->
                    <VBox alignment="CENTER" spacing="10">
                        <StackPane>
                            <javafx.scene.shape.Circle radius="50" fill="#e0e0e0"/>
                            <ImageView fx:id="profilePictureView" fitWidth="100" fitHeight="100" preserveRatio="true">
                                <clip>
                                    <javafx.scene.shape.Circle radius="50" centerX="50" centerY="50"/>
                                </clip>
                            </ImageView>
                        </StackPane>
                        <Label fx:id="profilePictureLabel" text="No profile picture" style="-fx-font-size: 11; -fx-text-fill: #888;"/>
                    </VBox>
                    
                    <!-- User Info -->
                    <VBox spacing="10" HBox.hgrow="ALWAYS">
                        <HBox spacing="10" alignment="CENTER_LEFT">
                            <Label text="Name:" style="-fx-font-weight: bold; -fx-min-width: 100;"/>
                            <Label fx:id="nameLabel" text="Loading..." style="-fx-text-fill: #555;"/>
                        </HBox>
                        <HBox spacing="10" alignment="CENTER_LEFT">
                            <Label text="Email:" style="-fx-font-weight: bold; -fx-min-width: 100;"/>
                            <Label fx:id="emailLabel" text="Loading..." style="-fx-text-fill: #555;"/>
                        </HBox>
                        <HBox spacing="10" alignment="CENTER_LEFT">
                            <Label text="Role:" style="-fx-font-weight: bold; -fx-min-width: 100;"/>
                            <Label fx:id="roleLabel" text="Loading..." style="-fx-text-fill: #555;"/>
                        </HBox>
                    </VBox>
                </HBox>
            </VBox>

            <!-- Authentication Methods Section -->
            <VBox spacing="15" style="-fx-background-color: white; -fx-padding: 25; -fx-background-radius: 15; -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.1), 10, 0, 0, 2);">
                <Label text="Authentication Methods" style="-fx-font-size: 20; -fx-font-weight: bold; -fx-text-fill: #667eea;"/>
                <Label text="Manage how you sign in to your account" style="-fx-font-size: 13; -fx-text-fill: #888;"/>
                
                <!-- Password Authentication -->
                <HBox spacing="15" alignment="CENTER_LEFT" style="-fx-padding: 15; -fx-background-color: #f9f9f9; -fx-background-radius: 10;">
                    <VBox spacing="5" HBox.hgrow="ALWAYS">
                        <Label text="🔑 Password Authentication" style="-fx-font-size: 15; -fx-font-weight: bold;"/>
                        <Label fx:id="passwordStatusLabel" text="Enabled" style="-fx-font-size: 12; -fx-text-fill: #27ae60;"/>
                    </VBox>
                    <Button text="Change Password" onAction="#handleChangePassword" 
                            style="-fx-background-color: #667eea; -fx-text-fill: white; -fx-padding: 8 15; -fx-background-radius: 8; -fx-cursor: hand;"/>
                </HBox>

                <!-- Google OAuth -->
                <HBox spacing="15" alignment="CENTER_LEFT" style="-fx-padding: 15; -fx-background-color: #f9f9f9; -fx-background-radius: 10;">
                    <VBox spacing="5" HBox.hgrow="ALWAYS">
                        <Label text="🔐 Google Account" style="-fx-font-size: 15; -fx-font-weight: bold;"/>
                        <Label fx:id="googleStatusLabel" text="Not connected" style="-fx-font-size: 12; -fx-text-fill: #888;"/>
                        <Label fx:id="googleEmailLabel" text="" style="-fx-font-size: 11; -fx-text-fill: #666;" visible="false"/>
                    </VBox>
                    <Button fx:id="googleActionButton" text="Connect Google" onAction="#handleGoogleAction" 
                            style="-fx-background-color: white; -fx-border-color: #dadce0; -fx-border-width: 1; -fx-text-fill: #3c4043; -fx-padding: 8 15; -fx-background-radius: 8; -fx-cursor: hand;"/>
                </HBox>

                <!-- Signature Authentication -->
                <HBox spacing="15" alignment="CENTER_LEFT" style="-fx-padding: 15; -fx-background-color: #f9f9f9; -fx-background-radius: 10;">
                    <VBox spacing="5" HBox.hgrow="ALWAYS">
                        <Label text="✍️ Signature Authentication" style="-fx-font-size: 15; -fx-font-weight: bold;"/>
                        <Label fx:id="signatureStatusLabel" text="Not set up" style="-fx-font-size: 12; -fx-text-fill: #888;"/>
                    </VBox>
                    <Button text="Set Up Signature" onAction="#handleSetupSignature" 
                            style="-fx-background-color: #667eea; -fx-text-fill: white; -fx-padding: 8 15; -fx-background-radius: 8; -fx-cursor: hand;"/>
                </HBox>
            </VBox>

            <!-- Danger Zone -->
            <VBox spacing="15" style="-fx-background-color: #fff5f5; -fx-padding: 25; -fx-background-radius: 15; -fx-border-color: #e74c3c; -fx-border-width: 2; -fx-border-radius: 15;">
                <Label text="⚠️ Danger Zone" style="-fx-font-size: 18; -fx-font-weight: bold; -fx-text-fill: #e74c3c;"/>
                <Label text="Irreversible actions that affect your account" style="-fx-font-size: 12; -fx-text-fill: #888;"/>
                
                <HBox spacing="15" alignment="CENTER_LEFT">
                    <VBox spacing="5" HBox.hgrow="ALWAYS">
                        <Label text="Delete Account" style="-fx-font-size: 14; -fx-font-weight: bold;"/>
                        <Label text="Permanently delete your account and all associated data" style="-fx-font-size: 11; -fx-text-fill: #666;"/>
                    </VBox>
                    <Button text="Delete Account" onAction="#handleDeleteAccount" 
                            style="-fx-background-color: #e74c3c; -fx-text-fill: white; -fx-padding: 8 15; -fx-background-radius: 8; -fx-cursor: hand;"/>
                </HBox>
            </VBox>

        </VBox>
    </ScrollPane>

</VBox>
