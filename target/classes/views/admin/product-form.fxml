<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<VBox spacing="15" style="-fx-padding: 25;"
      xmlns="http://javafx.com/javafx"
      xmlns:fx="http://javafx.com/fxml"
      fx:controller="com.esports.controllers.admin.ProductFormController">

    <Label fx:id="formTitle" text="Add Product"
           style="-fx-font-size: 18; -fx-font-weight: bold;"/>

    <GridPane hgap="10" vgap="12">

        <Label text="Name:" GridPane.rowIndex="0" GridPane.columnIndex="0"/>
        <VBox spacing="3" GridPane.rowIndex="0" GridPane.columnIndex="1">
            <TextField fx:id="nameField" promptText="Product name" prefWidth="300"/>
            <Label fx:id="nameError" style="-fx-text-fill: red; -fx-font-size: 11;"/>
        </VBox>

        <Label text="Category:" GridPane.rowIndex="1" GridPane.columnIndex="0"/>
        <VBox spacing="3" GridPane.rowIndex="1" GridPane.columnIndex="1">
            <ComboBox fx:id="categoryBox" prefWidth="300"/>
            <Label fx:id="categoryError" style="-fx-text-fill: red; -fx-font-size: 11;"/>
        </VBox>

        <Label text="Description:" GridPane.rowIndex="2" GridPane.columnIndex="0"/>
        <VBox spacing="3" GridPane.rowIndex="2" GridPane.columnIndex="1">
            <TextArea fx:id="descriptionField" promptText="Description" prefWidth="300" prefHeight="80"/>
            <Label fx:id="descriptionError" style="-fx-text-fill: red; -fx-font-size: 11;"/>
        </VBox>

        <Label text="Price:" GridPane.rowIndex="3" GridPane.columnIndex="0"/>
        <VBox spacing="3" GridPane.rowIndex="3" GridPane.columnIndex="1">
            <TextField fx:id="priceField" promptText="Product price" prefWidth="300"/>
            <Label fx:id="priceError" style="-fx-text-fill: red; -fx-font-size: 11;"/>
        </VBox>

        <Label text="Stock:" GridPane.rowIndex="4" GridPane.columnIndex="0"/>
        <VBox spacing="3" GridPane.rowIndex="4" GridPane.columnIndex="1">
            <TextField fx:id="stockField" promptText="Available stock" prefWidth="300"/>
            <Label fx:id="stockError" style="-fx-text-fill: red; -fx-font-size: 11;"/>
        </VBox>

        <Label text="Image:" GridPane.rowIndex="5" GridPane.columnIndex="0"/>
        <VBox spacing="3" GridPane.rowIndex="5" GridPane.columnIndex="1">
            <HBox spacing="8">
                <TextField fx:id="imageField" promptText="image.jpg" prefWidth="230"/>
                <Button text="Browse..." onAction="#handleBrowse"/>
            </HBox>
            <Label fx:id="imageError" style="-fx-text-fill: red; -fx-font-size: 11;"/>
        </VBox>

        <Label text="Active:" GridPane.rowIndex="6" GridPane.columnIndex="0"/>
        <CheckBox fx:id="activeCheckBox" text="Available"
                  GridPane.rowIndex="6" GridPane.columnIndex="1"/>

    </GridPane>

    <Label fx:id="successMessage" style="-fx-text-fill: green; -fx-font-size: 12;"/>

    <HBox spacing="10">
        <Button fx:id="saveButton" text="Save" onAction="#handleSaveProduct"
                style="-fx-background-color: #2ecc71; -fx-text-fill: white;"/>
        <Button text="Clear" onAction="#handleClear"
                style="-fx-background-color: #f39c12; -fx-text-fill: white;"/>
        <Button text="Cancel" onAction="#handleCancel"/>
    </HBox>

</VBox>