<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<VBox spacing="15" style="-fx-padding: 25;"
      xmlns="http://javafx.com/javafx"
      xmlns:fx="http://javafx.com/fxml"
      fx:controller="com.esports.controllers.admin.GameFormController">

    <Label fx:id="formTitle" text="Add Game"
           style="-fx-font-size: 18; -fx-font-weight: bold;"/>

    <GridPane hgap="10" vgap="12">
        <Label text="Name:"        GridPane.rowIndex="0" GridPane.columnIndex="0"/>
        <HBox spacing="8" GridPane.rowIndex="0" GridPane.columnIndex="1">
            <TextField fx:id="nameField" promptText="Game name" prefWidth="220"/>
            <Button text="Fetch from RAWG" onAction="#handleFetchRawg"
                    style="-fx-background-color: #3498db; -fx-text-fill: white;"/>
        </HBox>

        <Label text="Slug:"        GridPane.rowIndex="1" GridPane.columnIndex="0"/>
        <TextField fx:id="slugField" promptText="game-slug" prefWidth="300"
                   GridPane.rowIndex="1" GridPane.columnIndex="1"/>

        <Label text="Description:" GridPane.rowIndex="2" GridPane.columnIndex="0"/>
        <TextArea fx:id="descField" promptText="Description" prefWidth="300" prefHeight="80"
                  GridPane.rowIndex="2" GridPane.columnIndex="1"/>

        <Label text="Has Ranking:" GridPane.rowIndex="3" GridPane.columnIndex="0"/>
        <CheckBox fx:id="rankingCheck"
                  GridPane.rowIndex="3" GridPane.columnIndex="1"/>

        <Label text="Cover Image:" GridPane.rowIndex="4" GridPane.columnIndex="0"/>
        <HBox spacing="8" GridPane.rowIndex="4" GridPane.columnIndex="1">
            <TextField fx:id="coverField" promptText="image-filename.jpg" prefWidth="150"/>
            <Button text="Browse..." onAction="#handleBrowse"/>
        </HBox>
    </GridPane>

    <HBox spacing="10">
        <Button text="Save"   onAction="#handleSave"
                style="-fx-background-color: #2ecc71; -fx-text-fill: white;"/>
        <Button text="Delete" fx:id="deleteBtn" onAction="#handleDelete"
                style="-fx-background-color: #e74c3c; -fx-text-fill: white;"/>
        <Button text="Cancel" onAction="#handleCancel"/>
    </HBox>

</VBox>